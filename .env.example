# BusinessPilot AI Environment Variables

# The Gemini API Key required for the LLM agents (google-genai SDK)
GEMINI_API_KEY=your_gemini_api_key_here

# Logging Configuration
LOG_LEVEL=INFO

# Optional: Notification configurations (e.g. SMTP for sending emails)
# If left empty, notifications will be simulated in the console logs
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
NOTIFICATION_RECIPIENT=stakeholder@example.com
